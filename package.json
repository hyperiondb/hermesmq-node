{
  "name": "hermesmq-node",
  "version": "0.2.4",
  "description": "Native Node.js client for hermesmq, a Raft-replicated message queue.",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "GPL-3.0-or-later",
  "keywords": [
    "message-queue",
    "raft",
    "pubsub",
    "queue"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hyperiondb/hermesmq-node.git"
  },
  "bugs": {
    "url": "https://github.com/hyperiondb/hermesmq-node/issues"
  },
  "homepage": "https://github.com/hyperiondb/hermesmq-node#readme",
  "engines": {
    "node": ">= 20"
  },
  "author": "Tadas Talaikis <info@nordlet.com>",
  "napi": {
    "binaryName": "hermesmq-node",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-musl",
      "x86_64-pc-windows-msvc"
    ]
  },
  "files": [
    "index.js",
    "index.d.ts"
  ],
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "test": "node smoke.mjs && node subscribe-smoke.mjs && node pipeline-smoke.mjs"
  },
  "devDependencies": {
    "@napi-rs/cli": "3.7.0"
  }
}
